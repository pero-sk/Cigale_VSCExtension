{
  "name": "cigale",
  "displayName": "cigale",
  "description": "Cigale language support for Visual Studio Code",
  "version": "0.0.1",
  "repository": "https://github.com/pero-sk/Cigale_VSCExtension",
  "publisher": "pero-sk",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "cigale",
      "aliases": ["Cigale", "cigale"],
      "extensions": [".cig"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "cigale",
      "scopeName": "source.cig",
      "path": "./syntaxes/cigale.tmLanguage.json"
    }],
    "snippets": [{
      "language": "cigale",
      "path": "./snippets/cigale.json"
    }]
  }
}
